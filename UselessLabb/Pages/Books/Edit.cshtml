@page
@model UselessLabb.Pages.Books.EditModel
@{
    ViewData["Title"] = "Редагувати книгу";
}

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1><i class="bi bi-pencil"></i> Редагувати книгу</h1>
            <hr />

            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Book.Id" />
                <input type="hidden" asp-for="Book.CoverImage" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Book.Title" class="form-label"></label>
                    <input asp-for="Book.Title" class="form-control" />
                    <span asp-validation-for="Book.Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Book.Author" class="form-label"></label>
                    <input asp-for="Book.Author" class="form-control" />
                    <span asp-validation-for="Book.Author" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Book.ISBN" class="form-label"></label>
                    <input asp-for="Book.ISBN" class="form-control" />
                    <span asp-validation-for="Book.ISBN" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Book.PublishDate" class="form-label"></label>
                        <input asp-for="Book.PublishDate" type="date" class="form-control" />
                        <span asp-validation-for="Book.PublishDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Book.Price" class="form-label"></label>
                        <input asp-for="Book.Price" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Book.Price" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Book.GenreId" class="form-label"></label>
                        <select asp-for="Book.GenreId" class="form-select" asp-items="Model.GenresList">
                            <option value="">-- Оберіть жанр --</option>
                        </select>
                        <span asp-validation-for="Book.GenreId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Book.PublisherId" class="form-label"></label>
                        <select asp-for="Book.PublisherId" class="form-select" asp-items="Model.PublishersList">
                            <option value="">-- Оберіть видавництво --</option>
                        </select>
                        <span asp-validation-for="Book.PublisherId" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Book.Description" class="form-label"></label>
                    <textarea asp-for="Book.Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Book.Description" class="text-danger"></span>
                </div>

                @if (!string.IsNullOrEmpty(Model.Book.CoverImage))
                {
                    <div class="mb-3">
                        <label class="form-label">Поточна обкладинка:</label><br />
                        <img src="@Model.Book.CoverImage" alt="Current cover" style="max-width: 200px; max-height: 300px;" class="img-thumbnail" />
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="CoverImageFile" class="form-label">Нова обкладинка (необов'язково)</label>
                    <input asp-for="CoverImageFile" type="file" class="form-control" accept="image/*" />
                    <span asp-validation-for="CoverImageFile" class="text-danger"></span>
                    <small class="form-text text-muted">Залиште порожнім, щоб зберегти поточну обкладинку</small>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Зберегти зміни
                    </button>
                    <a asp-page="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Назад до списку
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
