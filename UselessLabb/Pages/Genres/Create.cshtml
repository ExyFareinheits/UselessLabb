@page
@model UselessLabb.Pages.Genres.CreateModel
@{
    ViewData["Title"] = "Додати жанр";
}

<div class="container">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1><i class="bi bi-plus-circle"></i> Додати новий жанр</h1>
            <hr />

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Genre.Name" class="form-label"></label>
                    <input asp-for="Genre.Name" class="form-control" placeholder="Введіть назву жанру" />
                    <span asp-validation-for="Genre.Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Genre.Description" class="form-label"></label>
                    <textarea asp-for="Genre.Description" class="form-control" rows="4" placeholder="Введіть опис жанру"></textarea>
                    <span asp-validation-for="Genre.Description" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Зберегти
                    </button>
                    <a asp-page="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Назад до списку
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
